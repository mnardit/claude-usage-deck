{
  "manifest_version": 3,
  "name": "Claude Usage Deck",
  "version": "1.0.0",
  "description": "Monitor your Claude.ai usage limits at a glance — badge shows weekly usage %, popup shows all metrics with countdowns.",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
